{
  "name": "@ai-western-town/local-host",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @ai-western-town/contracts build && tsc -p tsconfig.json",
    "typecheck": "pnpm --filter @ai-western-town/contracts build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && node --test dist/**/*.test.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@ai-western-town/contracts": "workspace:*",
    "fastify": "^5.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6"
  }
}
