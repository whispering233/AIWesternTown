# 复制本文件为 .env.local 后用于本地开发。
# 密钥只应写入 .env.local，不要提交到仓库。

# local-host HTTP 服务。
# 浏览器应用通过 VITE_LOCAL_HOST_URL 连接到这个 API。
LOCAL_HOST_PORT=8787
LOCAL_HOST_BIND=127.0.0.1

# Web 开发服务器。
# Vite 只会把 VITE_* 变量暴露给浏览器代码。
VITE_LOCAL_HOST_URL=http://127.0.0.1:8787
VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=5173

# LLM provider 选择。
# 可选值：mock、local、cloud。
LLM_PROVIDER=local

# Mock provider 的回退/调试响应。
# 仅在 LLM_PROVIDER=mock 时使用。
LLM_MOCK_RESPONSE={"narration":"The town holds its breath.","dialogue":[],"safetyFlags":[]}

# 本地 OpenAI-compatible provider。
# LM Studio 默认通常是 http://127.0.0.1:1234/v1。
# Ollama OpenAI-compatible endpoint 通常是 http://127.0.0.1:11434/v1。
LLM_LOCAL_BASE_URL=http://127.0.0.1:1234/v1
LLM_LOCAL_API_KEY=
LLM_LOCAL_PROVIDER_NAME=local

# 本地模型选择。
# local-host 优先读取 LLM_LOCAL_MODEL，LLM_MODEL 是通用回退项。
LLM_LOCAL_MODEL=gemma-4-e2b-uncensored-hauhaucs-aggressive
LLM_MODEL=gemma-4-e2b-uncensored-hauhaucs-aggressive

# 只有本地 provider 稳定支持 OpenAI JSON object mode 时才设置为 true 或 1。
LLM_LOCAL_SUPPORTS_JSON_OBJECT=false

# Provider 调用超时时间，单位毫秒。
LLM_TIMEOUT_MS=30000

# Cloud provider 占位名称。
# 仅在 LLM_PROVIDER=cloud 时使用；当前 cloud adapter 仍是占位实现。
LLM_CLOUD_PROVIDER_NAME=cloud
