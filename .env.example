# Copy this file to .env.local for local development.

# local-host
LOCAL_HOST_PORT=8787
LOCAL_HOST_BIND=127.0.0.1

# web
# Vite exposes only VITE_* variables to browser code.
# VITE_LOCAL_HOST_URL points the browser app at the local-host API.
VITE_LOCAL_HOST_URL=http://127.0.0.1:8787
# VITE_DEV_HOST and VITE_DEV_PORT control the Vite dev server itself.
VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=5173

# llm-runtime
LLM_PROVIDER=mock
LLM_LOCAL_BASE_URL=http://127.0.0.1:1234/v1
LLM_LOCAL_API_KEY=
LLM_LOCAL_PROVIDER_NAME=local
